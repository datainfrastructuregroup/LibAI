---
layout: base.njk
---

<article class="note">
    <header>
        <h1>{{ title }}</h1>
        <div class="meta">
            <a href="{{ "/notes" | url }}" class="back-link">← Back to all notes</a>
        </div>
        
        {% if authors and authors.length > 0 or contributors and contributors.length > 0 or editors and editors.length > 0 %}
        <div class="note-byline">
            {% if authors and authors.length > 0 %}
            <div class="byline-section">
                <span class="byline-label">Written by:</span>
                <span class="byline-content">
                    {% for author in authors %}
                        {% set authorName = author | replace("[[", "") | replace("]]", "") %}
                        {% set authorPage = collections.all | getEntryByUrl("/people/" + authorName + "/") %}
                        {% if authorPage %}
                            <a href="{{ "/people/" | url }}{{ authorName }}/">{{ authorPage.data.title }}</a>{% if not loop.last %}, {% endif %}
                        {% else %}
                            <span>{{ authorName }}</span>{% if not loop.last %}, {% endif %}
                        {% endif %}
                    {% endfor %}
                </span>
            </div>
            {% endif %}
            
            {% if contributors and contributors.length > 0 %}
            {% set hasValidContributors = false %}
            {% for contributor in contributors %}
                {% if contributor and contributor != "" %}
                    {% set hasValidContributors = true %}
                {% endif %}
            {% endfor %}
            {% if hasValidContributors %}
            <div class="byline-section">
                <span class="byline-label">Additional contributions by:</span>
                <span class="byline-content">
                    {% for contributor in contributors %}
                        {% if contributor and contributor != "" %}
                        {% set contributorName = contributor | replace("[[", "") | replace("]]", "") %}
                        {% set contributorPage = collections.all | getEntryByUrl("/people/" + contributorName + "/") %}
                        {% if contributorPage %}
                            <a href="{{ "/people/" | url }}{{ contributorName }}/">{{ contributorPage.data.title }}</a>{% if not loop.last %}, {% endif %}
                        {% else %}
                            <span>{{ contributorName }}</span>{% if not loop.last %}, {% endif %}
                        {% endif %}
                        {% endif %}
                    {% endfor %}
                </span>
            </div>
            {% endif %}
            {% endif %}
            
{% if editors and editors.length > 0 %}
            {% set hasValidEditors = false %}
            {% for editor in editors %}
                {% if editor and editor != "" %}
                    {% set hasValidEditors = true %}
                {% endif %}
            {% endfor %}
            {% if hasValidEditors %}
            <div class="byline-section">
                <span class="byline-label">Edited by:</span>
                <span class="byline-content">
                    {% for editor in editors %}
                        {% if editor and editor != "" %}
                        {% set editorName = editor | replace("[[", "") | replace("]]", "") %}
                        {% set editorPage = collections.all | getEntryByUrl("/people/" + editorName + "/") %}
                        {% if editorPage %}
                            <a href="{{ "/people/" | url }}{{ editorName }}/">{{ editorPage.data.title }}</a>{% if not loop.last %}, {% endif %}
                        {% else %}
                            <span>{{ editorName }}</span>{% if not loop.last %}, {% endif %}
                        {% endif %}
                        {% endif %}
                    {% endfor %}
                </span>
            </div>
            {% endif %}
            {% endif %}
        </div>
        {% endif %}
    </header>
    
    <div class="content">
        {{ content | safe }}
    </div>
    
    <!-- Works Cited Section - Added by citations plugin -->
    {% if referencesByPage and referencesByPage[page.url] %}
    <section class="works-cited">
        <h2>Works Cited</h2>
        {% for reference in referencesByPage[page.url] %}
            <p>{{ reference.entry | safe }}</p>
        {% endfor %}
    </section>
    {% endif %}
    

    

</article>
